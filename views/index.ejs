<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <% if (locals.message) { %>
        <p><%= message %><p>
    <%} else { %>
    <h1>Hello World!</h1>
    <form action="/home/new-folder" method="post">
        <div>
            <label for="newFolder">New Folder</label>
            <input type="text" name="newFolder" id="newFolder" require>
        </div>
        <button type="submit">Create Folder</button>
    </form>

    <form action="/upload" method="get">
        <button type="submit">Upload</button>
    </form>

    <form action="/home/log-out" method="get">
        <button type="submit">Log Out</button>
    </form>

    <div>
        <% if (locals.folders) { %>
            <% folders.map(folder => { %>
                <div>
                    <%= folder.name%>
                </div>
            <% }) %>
        <% } %>

        <% if (locals.files) { %>
            <% files.map(file => { %>
                <div>
                    <span><%= file.fileName %></span>
                    <span><%= file.fileSize %></span>
                    <span><%= format(file.uploadedAt, 'PP') %></span>
                    <a href="/home/<%= file.id %>/download">download</a>
                </div>
            <% }) %>
        <% } %>
    </div>
    <% } %>
</body>
</html>