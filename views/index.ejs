<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <% if (locals.message) { %>
        <div class="logInErrorMsg"> 
            <p><%= message %><p>
            <a href="/">Back to log in</a>
        </div>
    <%} else { %>
    <%- include("partials/header.ejs") %>
    
    <%- include("partials/error.ejs") %>

    <div class="fileFolderUpload">
        <form action="/home/new-folder" method="post" class="newFolder">
            <div>
                <label for="newFolder">New Folder</label>
                <input type="text" name="newFolder" id="newFolder" required>
            </div>
            <button type="submit">Create</button>
        </form>

        <form action="/upload" method="get">
            <button type="submit">Upload</button>
        </form>
    </div>
    
    <div class="assetsContainer">
        <% if (locals.folders.length === 0 && locals.files.length === 0) { %>
            <p class="emptyMsg">You currently have no files or folders</p>
        <% } else { %>
            <div class="foldersContainer">
                <% if (locals.folders) { %>
                    <% folders.map(folder => { %>
                        <div class="folder">
                            <a href="/home/library/<%= folder.name %>" class="folderName">
                                <div>
                                    <%= folder.name%>
                                </div>
                            </a>
                            <form action="/home/<%= folder.id %>/delete-folder" method="get" class="deleteBtn">
                                <button type="submit">delete</button>
                            </form>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        
            <div class="filesContainer">
                <%- include("partials/file.ejs") %>
            </div>
        <% } %>
        
    </div>
    <% } %>
</body>
</html>