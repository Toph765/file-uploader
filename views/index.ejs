<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <% if (locals.message) { %>
        <p><%= message %><p>
    <%} else { %>
    <h1>Hello World!</h1>
    
    <%- include("partials/error.ejs") %>

    <form action="/home/new-folder" method="post">
        <div>
            <label for="newFolder">New Folder</label>
            <input type="text" name="newFolder" id="newFolder" required>
        </div>
        <button type="submit">Create Folder</button>
    </form>

    <form action="/upload" method="get">
        <button type="submit">Upload</button>
    </form>

    <form action="/home/log-out" method="get">
        <button type="submit">Log Out</button>
    </form>

    <div>
        <% if (locals.folders) { %>
            <% folders.map(folder => { %>
                <div class="folder">
                    <a href="/home/library/<%= folder.name %>">
                        <div>
                            <%= folder.name%>
                        </div>
                    </a>
                    <form action="/home/<%= folder.id %>/delete-folder" method="get">
                        <button type="submit">delete</button>
                    </form>
                </div>
            <% }) %>
        <% } %>

        <%- include("partials/file.ejs") %>
    </div>
    <% } %>
</body>
</html>